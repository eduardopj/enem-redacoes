{
  "cli": {
    "version": ">= 18.7.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://134-209-38-46.nip.io",
        "EXPO_PUBLIC_OPENAI_USE_BACKEND": "true",
        "EXPO_PUBLIC_API_TIMEOUT_MS": "150000",
        "EXPO_PUBLIC_APP_ENV": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://134-209-38-46.nip.io",
        "EXPO_PUBLIC_OPENAI_USE_BACKEND": "true",
        "EXPO_PUBLIC_OPENAI_MODEL": "gpt-4.1-mini",
        "EXPO_PUBLIC_API_TIMEOUT_MS": "150000",
        "EXPO_PUBLIC_APP_ENV": "staging",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://134-209-38-46.nip.io",
        "EXPO_PUBLIC_OPENAI_USE_BACKEND": "true",
        "EXPO_PUBLIC_OPENAI_MODEL": "gpt-4.1-mini",
        "EXPO_PUBLIC_API_TIMEOUT_MS": "150000",
        "EXPO_PUBLIC_APP_ENV": "production",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
