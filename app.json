{
  "expo": {
    "name": "Enem IA",
    "slug": "enem-redacoes",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "enemredacoes",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.eduardopj.enemredacoes",
      "buildNumber": "1",
      "deploymentTarget": "16.0",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "O app precisa acessar sua galeria para você escolher a foto da redação.",
        "NSPhotoLibraryAddUsageDescription": "O app pode salvar fotos da redação na sua galeria.",
        "NSMicrophoneUsageDescription": "O app pode precisar do microfone ao usar a câmera para fotografar redações.",
        "NSAppTransportSecurity": {
          "NSExceptionDomains": {
            "146.190.47.67": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": false
            }
          }
        }
      }
    },
    "android": {
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "allowBackup": false,
      "package": "com.eduardopj.enemredacoes",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7C3AED"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "androidNavigationBar": {
      "backgroundColor": "#FFFFFF",
      "barStyle": "dark-content"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#7C3AED",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "O app precisa da câmera para escanear o QR Code da turma e fotografar redações."
        }
      ],
      "expo-build-properties",
      "expo-font",
      [
        "@sentry/react-native/expo",
        {
          "uploadSourceMaps": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "be7dce9e-ec66-49d2-a774-58187eaf86ae"
      },
      "privacyPolicyUrl": "https://enemredacoes.app/privacidade"
    },
    "owner": "eduardopjr"
  }
}
