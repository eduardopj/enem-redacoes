{
  "expo": {
    "name": "Enem IA",
    "slug": "enem-redacoes",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "enemredacoes",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.eduardopj.enemredacoes",
      "buildNumber": "1"
    },
    "android": {
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "allowBackup": false,
      "package": "com.eduardopj.enemredacoes",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4E76F8"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "androidNavigationBar": {
      "backgroundColor": "#F7F4ED",
      "barStyle": "dark-content"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4E76F8",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "O app precisa da câmera para escanear o QR Code da turma e fotografar redações."
        }
      ],
      "expo-build-properties",
      "expo-font",
      "@sentry/react-native/expo"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e989326e-613c-4fd5-86ec-7b49ddae7b09"
      },
      "privacyPolicyUrl": "https://enemredacoes.app/privacidade"
    },
    "owner": "eduardopj"
  }
}
