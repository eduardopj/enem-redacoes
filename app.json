{
  "expo": {
    "name": "Enem IA",
    "slug": "enem-redacoes",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "enemredacoes",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "allowBackup": false,
      "package": "com.eduardopj.enemredacoes",
      "versionCode": 1,
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4E76F8"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "androidNavigationBar": {
      "backgroundColor": "#F7F4ED",
      "barStyle": "dark-content"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "O app precisa da câmera para escanear o QR Code da turma e fotografar redações."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b5b6eb55-360e-44ab-bcc6-6928c0a1bc58"
      }
    }
  }
}
