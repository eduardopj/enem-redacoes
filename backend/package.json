    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.4.1",
    "file-type": "^22.0.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "nodemailer": "^8.0.7",
    "openai": "^4.104.0",
    "p-queue": "^9.2.0",
    "p-retry": "^8.0.0",
    "postgres": "^3.4.9",
