# Backend environment variables — copy to .env and fill in real values

# Required
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4.1-mini
PORT=3333

# Optional — SMTP for password reset emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
SMTP_FROM=ENEM IA <no-reply@enemredacoes.app>

# Optional — Redis for distributed rate limiting (fallback: in-memory)
REDIS_URL=redis://localhost:6379

# Optional — S3 for image storage (fallback: local filesystem)
S3_BUCKET=
S3_REGION=us-east-1
S3_KEY_PREFIX=essays/
CDN_DOMAIN=

# Optional — Sentry error tracking
SENTRY_DSN=

# Optional — Custom data directory (default: ./data)
DATA_DIR=./data

# Optional — CORS allowed origins (comma-separated, default: *)
CORS_ORIGINS=*

# Optional — S3 offsite backup for SQLite DB (separate bucket from images)
# After each local backup succeeds, the .db file is also uploaded to S3.
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=us-east-1
BACKUP_S3_PREFIX=db-backups/
